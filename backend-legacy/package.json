{
  "name": "ss-ai-legacy-backend",
  "version": "0.1.0",
  "private": true,
  "description": "Legacy standalone backend kept for reference. The main app now runs from the repository root.",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc --noEmit -p tsconfig.json",
    "start": "node dist/main.js",
    "dev": "node --watch --loader ts-node/esm src/main.ts"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.3",
    "ts-node": "^10.9.2",
    "typescript": "^5.8.3"
  }
}
