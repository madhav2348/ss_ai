NODE_ENV=development
PORT=3000

# Local services
REDIS_URL=redis://localhost:6379

# AI
OPENAI_API_KEY=

# Storage
SCREENSHOT_STORAGE_DIR=./storage/screenshots
PROCESSED_STORAGE_DIR=./storage/processed
SQLITE_STORAGE_PATH=./storage/db/ss.db

# Google Drive integration
# Enable Google Drive API in Google Cloud, then add the OAuth client ID here.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Local screenshot source
# TODO: wire this into the background local watcher.
LOCAL_SCREENSHOT_SOURCE_DIR=

# Telegram integration
TELEGRAM_BOT_TOKEN=
# Future cloud storage integrations are tracked in TODO.md and intentionally
# not configured here until the provider code exists.
